# =============================================================================
# Environment Configuration — Cata Club Admin Frontend
# =============================================================================
# Copy this file to .env.local and fill in your values.
# This file is committed intentionally; .env.local is gitignored.
# =============================================================================

# --- Demo Mode (default) ---
# The app runs in demo mode with local mock data when NEXT_PUBLIC_USE_MOCKS
# is unset or set to "true". The header shows a "Demo" badge.
#
# In this mode, all API calls are served by Route Handlers under
# src/app/api/ using in-memory data from src/services/mockStore.ts.
# No backend is required. Data resets on server restart.

# --- Production / Backend Mode ---
# Set NEXT_PUBLIC_USE_MOCKS=false and BACKEND_API_URL (below) to the real
# Python backend URL when the backend service is available.

# --- API Configuration ---
# NOTE: NEXT_PUBLIC_API_URL is NOT read anywhere under frontend/src at
# runtime. It only exists as a `Dockerfile` build ARG (see frontend/Dockerfile)
# baked into the standalone build; it has no effect when running via
# `next dev`/`next start` or setting it in `.env.local`. The var that actually
# drives backend calls is `BACKEND_API_URL` below.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Controls whether the app uses local mock Route Handlers or the real backend.
# Mock handlers live under src/app/api/ and are automatically available
# at /api/* when running Next.js in dev mode.
#
# Default when unset or missing: **true** (local mocks / demo mode).
# Set to "false" explicitly to hit the real Python backend.
# Examples:
#   NEXT_PUBLIC_USE_MOCKS=true   -> local /api/* Route Handlers (demo)
#   NEXT_PUBLIC_USE_MOCKS=false  -> real backend via BACKEND_API_URL (server-only)
#   (unset)                       -> local /api/* Route Handlers (demo)

# --- Application ---
NEXT_PUBLIC_APP_NAME=Cata Club Admin
NEXT_PUBLIC_USE_MOCKS=false
# Server-only — el BFF de Next.js (src/app/api/auth/**) llama a FastAPI directo.
# NUNCA le pongas prefijo NEXT_PUBLIC_ — tiene que quedar invisible para el bundle del browser.
BACKEND_API_URL=http://localhost:8000/api/v1
