# Root env for docker-compose.yml — copy to .env and fill in.
#
# REQUIRED: JWT_SECRET_KEY must be set or docker-compose will fail to start.
# Generate a secure key:  openssl rand -hex 32

# --- Database (safe dev defaults baked into docker-compose.yml) ---
POSTGRES_USER=usuario
POSTGRES_PASSWORD=password
POSTGRES_DB=cataclub_db

# --- JWT (REQUIRED) ---
JWT_SECRET_KEY=

# --- Environment: "development" enables crear_tablas + seed on startup ---
AMBIENTE=development

# --- Cloudinary (optional — leave empty to skip file uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
