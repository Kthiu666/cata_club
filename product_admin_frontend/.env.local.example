# =============================================================================
# Environment Configuration — Product Admin Frontend
# =============================================================================
# Copy this file to .env.local and fill in your values.
# This file is committed intentionally; .env.local is gitignored.
# =============================================================================

# --- API Configuration ---
# Base URL of the Python backend API (when not using local mocks).
# Examples:
#   Development: http://localhost:8000/api/v1
#   Production:  https://api.example.com/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Set to "true" to use local mock Route Handlers instead of the real backend.
# Mock handlers live under src/app/api/ and are automatically available
# at /api/* when running Next.js in dev mode.
NEXT_PUBLIC_USE_MOCKS=true

# --- Cloudinary Configuration (Image Upload) ---
# The frontend uses unsigned upload presets for public product images.
# Cloud Name  — publicly safe, embedded in client-side code.
# Upload Preset — set to "unsigned" in your Cloudinary dashboard.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=product_admin_unsigned

# --- Application ---
NEXT_PUBLIC_APP_NAME=Product Admin
