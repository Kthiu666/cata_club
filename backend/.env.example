DATABASE_URL=postgresql+psycopg://usuario:password@localhost:5432/cataclub_db
JWT_SECRET_KEY=genera-una-clave-larga-y-aleatoria-aqui
JWT_ALGORITMO=HS256
JWT_EXPIRA_MINUTOS=60
JWT_REFRESH_EXPIRA_DIAS=7

# --- CORS ---
# Orígenes permitidos (frontend). Acepta CSV o JSON.
# Ejemplo CSV (recomendado, sin comillas ni corchetes):
#   CORS_ORIGENES=http://localhost:3000,https://cataclub.com
# Ejemplo JSON (también válido):
#   CORS_ORIGENES=["http://localhost:3000","https://cataclub.com"]
CORS_ORIGENES=http://localhost:3000

# --- Redis (broker + cache) ---
REDIS_URL=redis://localhost:6379/0
# Opcionales: si se quieren endpoints distintos para broker y result backend
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CARPETA_COMPROBANTES=cataclub/comprobantes
CLOUDINARY_CARPETA_VOUCHERS=cataclub/vouchers

# --- Development bulk seed ---
# Optional reachable fixture URL for scripts/seed_dev_bulk.py payment previews.
SEED_VOUCHER_BASE_URL=https://placehold.co/600x400.png?text=Cata+Club+Voucher

# --- Celery Beat ---
# Hora local (HH:MM) a la que se disparan las automatizaciones diarias
CELERY_HORA_AUTOMATIZACIONES=02:30

# Segundos que Celery conserva el resultado de una tarea antes de expirarlo (24h)
CELERY_RESULT_EXPIRA_SEGUNDOS=86400

# --- Entorno / metadata de la app (opcionales, ya tienen default en el codigo) ---
# AMBIENTE=production
# APP_NOMBRE=API Cata Club - UNL
# APP_VERSION=1.3.0

# --- Correo / SMTP (envio transaccional: recuperacion de contrasenia, etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@cataclub.com
SMTP_STARTTLS=true
# Base usada para construir enlaces de recuperacion de contrasenia en los correos
FRONTEND_URL=http://localhost:3000

# --- Chatbot de FAQ (gateway OpenCode Zen, OpenAI-compatible) ---
OPENCODE_API_KEY=

# --- Cloudinary (fotos de perfil self-service de cada Persona) ---
CLOUDINARY_CARPETA_FOTOS_PERFIL=cataclub/fotos_perfil
