# =============================================================================
# Environment Configuration — Cata Club Admin Frontend
# =============================================================================
# Copy this file to .env.local and fill in your values.
# This file is committed intentionally; .env.local is gitignored.
# =============================================================================

# --- API Configuration ---
# Base URL of the Python backend API (when not using local mocks).
# Examples:
#   Development: http://localhost:8000/api/v1
#   Production:  https://api.example.com/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Controls whether the app uses local mock Route Handlers or the real backend.
# Mock handlers live under src/app/api/ and are automatically available
# at /api/* when running Next.js in dev mode.
#
# Default when unset or missing: **true** (local mocks).
# Set to "false" explicitly to hit the real Python backend.
# Examples:
#   NEXT_PUBLIC_USE_MOCKS=true   -> local /api/* Route Handlers
#   NEXT_PUBLIC_USE_MOCKS=false  -> real backend at NEXT_PUBLIC_API_URL
#   (unset)                       -> local /api/* Route Handlers
NEXT_PUBLIC_USE_MOCKS=true

# --- Application ---
NEXT_PUBLIC_APP_NAME=Cata Club Admin
